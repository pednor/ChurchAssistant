{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash .claude/hooks/pre-commit-yaml.sh",
            "timeout": 10,
            "statusMessage": "Validating staged YAML..."
          }
        ]
      }
    ]
  }
}
